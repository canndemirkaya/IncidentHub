{
    "name": "incidenthub-api",
    "version": "0.1.0",
    "private": true,
    "scripts": {
        "start:dev": "ts-node-dev --respawn --transpile-only src/main.ts",
        "build": "tsc -p tsconfig.build.json",
        "start": "node dist/main.js",
        "prisma:generate": "prisma generate",
        "prisma:migrate": "prisma migrate dev --name init --skip-seed",
        "prisma:seed": "ts-node prisma/seed.ts",
        "test": "jest"
    },
    "dependencies": {
        "@nestjs/config": "^2.2.0",
        "@nestjs/common": "^9.0.0",
        "@nestjs/core": "^9.0.0",
        "@nestjs/platform-socket.io": "^9.0.0",
        "@nestjs/platform-express": "^9.0.0",
        "@nestjs/websockets": "^9.0.0",
        "@nestjs/swagger": "^6.2.2",
        "class-transformer": "^0.5.1",
        "class-validator": "^0.14.0",
        "@prisma/client": "^5.0.0",
        "reflect-metadata": "^0.1.13",
        "rxjs": "^7.8.0",
        "socket.io": "^4.7.2"
    },
    "devDependencies": {
        "swagger-ui-express": "^4.6.3",
        "supertest": "^6.3.3",
        "@nestjs/testing": "^9.0.0",
        "ts-node": "^10.9.1",
        "ts-node-dev": "^2.0.0",
        "typescript": "^5.1.6",
        "jest": "^29.0.0",
        "ts-jest": "^29.0.0",
        "@types/jest": "^29.0.0",
        "@types/node": "^20.0.0",
        "prisma": "^5.0.0"
    }
}